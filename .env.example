MYSQL_IMAGE=public.ecr.aws/docker/library/mysql:8.0
REDIS_IMAGE=redis:7-alpine
SILLYTAVERN_IMAGE=ghcr.io/sillytavern/sillytavern:latest

MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=silly_app
MYSQL_USER=silly
MYSQL_PASSWORD=change-this-db-password

APP_AUTH_SECRET=change-this-long-random-secret
APP_RUOYI_ADMIN_USERNAME=admin
APP_RUOYI_ADMIN_PASSWORD='{bcrypt}$2b$10$jijc3w0SPAuAXLCfPgVV5eQN15hXMuiJSLga/.YnPyGxBgxrkiu5G'
APP_RUOYI_JWT_SECRET=change-this-long-random-jwt-secret
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/silly_app?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=silly
SPRING_DATASOURCE_PASSWORD=change-this-db-password
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

SILLYTAVERN_BASE_URL=http://127.0.0.1:8000
SILLYTAVERN_PUBLIC_BASE_URL=http://127.0.0.1:8000
SILLYTAVERN_API_KEY=

TELEGRAM_BOT_TOKEN=

# Optional payment provider settings
APP_PAYMENT_WECHAT_H5_ENABLED=false
APP_PAYMENT_ALIPAY_WAP_ENABLED=false
APP_PAYMENT_TELEGRAM_STARS_ENABLED=false
