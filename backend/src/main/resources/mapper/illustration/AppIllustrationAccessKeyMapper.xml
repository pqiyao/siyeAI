<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.sillyspringboot.illustration.mapper.AppIllustrationAccessKeyMapper">

    <resultMap id="AccessKeyResultMap" type="com.example.sillyspringboot.illustration.entity.AppIllustrationAccessKey">
        <id column="id" property="id"/>
        <result column="access_code" property="accessCode"/>
        <result column="content_level" property="contentLevel"/>
        <result column="expires_at" property="expiresAt"/>
        <result column="active" property="active"/>
        <result column="max_uses" property="maxUses"/>
        <result column="used_count" property="usedCount"/>
        <result column="note" property="note"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="BaseColumns">
        id, access_code, content_level, expires_at, active, max_uses, used_count,
        note, created_by, created_at, updated_at
    </sql>

    <sql id="AdminWhere">
        <where>
            <if test="keyword != null and keyword != ''">
                (
                    access_code LIKE CONCAT('%', #{keyword}, '%')
                    OR COALESCE(note, '') LIKE CONCAT('%', #{keyword}, '%')
                    OR COALESCE(created_by, '') LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="active != null">
                <if test="keyword != null and keyword != ''">AND</if>
                active = #{active}
            </if>
        </where>
    </sql>

    <select id="countAdminList" resultType="long">
        SELECT COUNT(1)
        FROM app_illustration_access_key
        <include refid="AdminWhere"/>
    </select>

    <select id="listAdminPage" resultMap="AccessKeyResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM app_illustration_access_key
        <include refid="AdminWhere"/>
        ORDER BY created_at DESC, id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="findById" resultMap="AccessKeyResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM app_illustration_access_key
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="findByCode" resultMap="AccessKeyResultMap">
        SELECT <include refid="BaseColumns"/>
        FROM app_illustration_access_key
        WHERE access_code = #{accessCode}
        LIMIT 1
    </select>

    <insert id="insert" parameterType="com.example.sillyspringboot.illustration.entity.AppIllustrationAccessKey" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO app_illustration_access_key (
            access_code, content_level, expires_at, active, max_uses, used_count, note, created_by
        ) VALUES (
            #{accessCode}, #{contentLevel}, #{expiresAt}, #{active}, #{maxUses}, #{usedCount}, #{note}, #{createdBy}
        )
    </insert>

    <update id="disableById">
        UPDATE app_illustration_access_key
        SET active = 0,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <delete id="hardDeleteById">
        DELETE FROM app_illustration_access_key
        WHERE id = #{id}
    </delete>
</mapper>
